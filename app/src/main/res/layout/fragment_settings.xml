<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:orientation="vertical">

    <TextView
        android:id="@+id/tv_settings_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_title"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="@color/colorOnBackground"
        android:letterSpacing="0.02"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="16dp" />

    <ScrollView
        android:id="@+id/settings_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:paddingBottom="24dp">

            <!-- File Receive Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/cardBackground"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/dividerColor"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="20dp"
                            android:background="@color/colorPrimary"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_receive_mode"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorOnSurface" />
                    </LinearLayout>

                    <CheckBox
                        android:id="@+id/cb_save_local"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_save_local"
                        android:textColor="@color/colorOnSurface"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp" />

                    <CheckBox
                        android:id="@+id/cb_upload_cloud"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_upload_cloud"
                        android:textColor="@color/colorOnSurface"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:id="@+id/upload_config_area"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/upload_url_label"
                            android:textSize="13sp"
                            android:textColor="@color/colorOnSurface"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp" />

                        <EditText
                            android:id="@+id/et_upload_url"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:hint="@string/upload_url_hint"
                            android:inputType="textUri"
                            android:padding="12dp"
                            android:textSize="13sp"
                            android:background="@drawable/edit_bg"
                            android:layout_marginBottom="12dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/upload_headers_label"
                            android:textSize="13sp"
                            android:textColor="@color/colorOnSurface"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp" />

                        <EditText
                            android:id="@+id/et_upload_headers"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:hint="@string/upload_headers_hint"
                            android:inputType="text"
                            android:padding="12dp"
                            android:textSize="13sp"
                            android:background="@drawable/edit_bg"
                            android:layout_marginBottom="12dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="end|center_vertical">

                            <Button
                                android:id="@+id/btn_test_upload"
                                android:layout_width="wrap_content"
                                android:layout_height="40dp"
                                android:text="@string/btn_test"
                                android:textColor="@color/colorPrimary"
                                android:textSize="13sp"
                                android:textAllCaps="false"
                                android:stateListAnimator="@null"
                                android:paddingLeft="20dp"
                                android:paddingRight="20dp"
                                android:layout_marginEnd="12dp"
                                android:backgroundTint="@color/colorBackground"
                                app:strokeColor="@color/colorPrimary"
                                app:strokeWidth="1dp"
                                app:cardCornerRadius="10dp" />

                            <Button
                                android:id="@+id/btn_save_upload"
                                android:layout_width="wrap_content"
                                android:layout_height="40dp"
                                android:text="@string/btn_save_upload"
                                android:textColor="@color/colorOnPrimary"
                                android:textSize="13sp"
                                android:textAllCaps="false"
                                android:stateListAnimator="@null"
                                android:paddingLeft="20dp"
                                android:paddingRight="20dp"
                                android:backgroundTint="@color/colorPrimary" />
                        </LinearLayout>

                    </LinearLayout>

                    <CheckBox
                        android:id="@+id/cb_share_social"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_share_social"
                        android:textColor="@color/colorOnSurface"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Export Log Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/cardBackground"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/dividerColor"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="20dp"
                            android:background="@color/colorPrimary"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_log"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorOnSurface" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_log_desc"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.4"
                        android:textColor="@color/tabInactiveColor"
                        android:layout_marginBottom="14dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <Button
                            android:id="@+id/btn_view_log"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:text="@string/settings_log_view"
                            android:textColor="@color/colorOnPrimary"
                            android:textSize="13sp"
                            android:textAllCaps="false"
                            android:backgroundTint="@color/colorPrimary"
                            android:stateListAnimator="@null"
                            android:paddingLeft="20dp"
                            android:paddingRight="20dp"
                            android:layout_marginEnd="12dp" />

                        <Button
                            android:id="@+id/btn_export_log"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:text="@string/settings_log_export"
                            android:textColor="@color/colorOnPrimary"
                            android:textSize="13sp"
                            android:textAllCaps="false"
                            android:backgroundTint="@color/colorPrimary"
                            android:stateListAnimator="@null"
                            android:paddingLeft="20dp"
                            android:paddingRight="20dp"
                            android:layout_marginEnd="12dp" />

                        <Button
                            android:id="@+id/btn_clear_log"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:text="@string/settings_log_clear"
                            android:textColor="@color/colorOnPrimary"
                            android:textSize="13sp"
                            android:textAllCaps="false"
                            android:backgroundTint="@color/colorPrimary"
                            android:stateListAnimator="@null"
                            android:paddingLeft="20dp"
                            android:paddingRight="20dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Language Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/cardBackground"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/dividerColor"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="20dp"
                            android:background="@color/colorPrimary"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_language"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorOnSurface" />
                    </LinearLayout>

                    <RadioGroup
                        android:id="@+id/rg_language"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <RadioButton
                            android:id="@+id/rb_zh"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/language_zh"
                            android:textColor="@color/colorOnSurface"
                            android:textSize="14sp" />
                        <RadioButton
                            android:id="@+id/rb_en"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/language_en"
                            android:textColor="@color/colorOnSurface"
                            android:textSize="14sp" />
                    </RadioGroup>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Check Update Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/cardBackground"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/dividerColor"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="20dp"
                            android:background="@color/colorPrimary"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_check_update"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorOnSurface" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1" />

                        <TextView
                            android:id="@+id/tv_version"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:textColor="@color/tabInactiveColor" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_update_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/tabInactiveColor"
                        android:visibility="gone"
                        android:layout_marginBottom="10dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <Button
                            android:id="@+id/btn_check_update"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:text="@string/settings_check_update"
                            android:textColor="@color/colorOnPrimary"
                            android:textSize="13sp"
                            android:textAllCaps="false"
                            android:backgroundTint="@color/colorPrimary"
                            android:stateListAnimator="@null"
                            android:paddingLeft="20dp"
                            android:paddingRight="20dp" />

                        <Button
                            android:id="@+id/btn_download_update"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:text="@string/update_download"
                            android:textColor="@color/colorOnPrimary"
                            android:textSize="13sp"
                            android:textAllCaps="false"
                            android:backgroundTint="@color/colorPrimary"
                            android:stateListAnimator="@null"
                            android:paddingLeft="20dp"
                            android:paddingRight="20dp"
                            android:layout_marginStart="12dp"
                            android:visibility="gone" />

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Open Source Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/cardBackground"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/dividerColor"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="20dp"
                            android:background="@color/colorPrimary"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_opensource"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorOnSurface" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_opensource_url"
                        android:textSize="13sp"
                        android:textColor="@color/colorPrimary"
                        android:layout_marginBottom="12dp" />

                    <Button
                        android:id="@+id/btn_opensource"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="@string/settings_opensource_btn"
                        android:textColor="@color/colorOnPrimary"
                        android:textSize="13sp"
                        android:textAllCaps="false"
                        android:backgroundTint="@color/colorPrimary"
                        android:stateListAnimator="@null"
                        android:paddingLeft="20dp"
                        android:paddingRight="20dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- About Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/cardBackground"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/dividerColor"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="20dp"
                            android:background="@color/colorPrimary"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_about"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorOnSurface" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/about_text"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.4"
                        android:textColor="@color/tabInactiveColor"
                        android:layout_marginBottom="10dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>