<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/dialog_bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/dialog_header_bg"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/dialog_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/colorOnPrimary"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Body -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/dialog_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/colorOnSurface"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.5" />

        <!-- 复制错误按钮，默认隐藏，出错时显示 -->
        <Button
            android:id="@+id/btn_copy_error"
            style="?attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:text="@string/copy_error"
            android:textColor="@color/colorError"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:paddingLeft="0dp"
            android:paddingRight="0dp"
            android:paddingTop="6dp"
            android:paddingBottom="0dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        android:background="@color/dividerColor" />

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end|center_vertical"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="12dp">

        <!-- 关闭：始终显示 -->
        <TextView
            android:id="@+id/btn_close"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="@string/btn_close"
            android:textColor="@color/tabInactiveColor"
            android:textSize="14sp"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/btn_text_bg"
            android:clickable="true"
            android:focusable="true" />

        <!-- 保存：仅勾选本地存储时显示 -->
        <TextView
            android:id="@+id/btn_save"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="@string/btn_save"
            android:textColor="@color/colorOnPrimary"
            android:textSize="14sp"
            android:paddingLeft="14dp"
            android:paddingRight="14dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/btn_primary_bg"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone" />

        <!-- 上传：仅勾选云端存储时显示 -->
        <TextView
            android:id="@+id/btn_upload"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="@string/btn_upload"
            android:textColor="@color/colorOnPrimary"
            android:textSize="14sp"
            android:paddingLeft="14dp"
            android:paddingRight="14dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/btn_primary_bg"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone" />

        <!-- 分享：仅勾选社交平台时显示 -->
        <TextView
            android:id="@+id/btn_share"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="@string/btn_share"
            android:textColor="@color/colorOnPrimary"
            android:textSize="14sp"
            android:paddingLeft="14dp"
            android:paddingRight="14dp"
            android:background="@drawable/btn_primary_bg"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout>
