<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/multi_action_bar"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:background="@color/colorSurface"
    android:elevation="8dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:visibility="gone">

    <TextView
        android:id="@+id/btn_multi_save"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:text="@string/files_action_save"
        android:textColor="@color/colorPrimary"
        android:textSize="14sp"
        android:textStyle="bold" />

    <View
        android:layout_width="1dp"
        android:layout_height="32dp"
        android:layout_gravity="center_vertical"
        android:background="@color/dividerColor" />

    <TextView
        android:id="@+id/btn_multi_delete"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:text="@string/files_action_delete"
        android:textColor="@color/colorError"
        android:textSize="14sp"
        android:textStyle="bold" />

    <View
        android:layout_width="1dp"
        android:layout_height="32dp"
        android:layout_gravity="center_vertical"
        android:background="@color/dividerColor" />

    <TextView
        android:id="@+id/btn_multi_share"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:text="@string/files_action_share"
        android:textColor="@color/colorPrimary"
        android:textSize="14sp"
        android:textStyle="bold" />
</LinearLayout>